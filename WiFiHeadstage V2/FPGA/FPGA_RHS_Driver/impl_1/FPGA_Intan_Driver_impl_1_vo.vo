  wire   GNDI, DI1_dly, CLK_dly, CE_dly, LSR_dly;

  lut40371 \Controller_inst/SPI_Master_CS_STM32_1/SPI_Master_1/i9596_3_lut ( 
    .A(A1), .B(GNDI), .C(C1), .D(D1), .Z(F1));
