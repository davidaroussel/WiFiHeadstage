  BB_B_B \o_RHS_TOP_SPI_CS_n_1_pad.bb_inst ( .T_N(VCCI), .I(PADDO), .O(), 
    .B(o_RHS_TOP_SPI_CS_n_1));
  vcc DRIVEVCC( .PWR1(VCCI));

  specify
    (PADDO => o_RHS_TOP_SPI_CS_n_1) = (0:0:0,0:0:0);
  endspecify

endmodule

