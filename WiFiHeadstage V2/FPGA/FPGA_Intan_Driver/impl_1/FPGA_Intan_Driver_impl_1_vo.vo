module lut40046 ( input A, B, C, D, output Z );

  LUT4 #("0xAB00") INST10( .A(A), .B(B), .C(C), .D(D), .Z(Z));
endmodule

module lut40047 ( input A, B, C, D, output Z );

  LUT4 #("0xAA02") INST10( .A(A), .B(B), .C(C), .D(D), .Z(Z));
endmodule

