  BB_B_B \i_RHD2216_SPI_MISO_pad.bb_inst ( .T_N(GNDI), .I(GNDI), .O(PADDI), 
    .B(i_RHD2216_SPI_MISO));
  gnd DRIVEGND( .PWR0(GNDI));

  specify
    (i_RHD2216_SPI_MISO => PADDI) = (0:0:0,0:0:0);
  endspecify

endmodule

